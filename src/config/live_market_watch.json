  },
  "risk": {
    "risk_per_trade_pct": 0.5,
    "soft_daily_reduction_pct": -1.5,
    "block_new_trades_daily_pct": -3.0,
    "force_close_daily_pct": -4.5,
    "block_new_trades_total_pct": -8.0,
    "force_close_total_pct": -9.5,
    "allow_multiple_positions": true,
    "max_open_positions_total": 7,
    "max_open_positions_per_symbol": 1,
    "max_new_trades_per_session": 7,
    "max_correlated_positions": 7,
    "same_direction_correlation_cap": 5,
    "dynamic_lot_sizing": true,
    "max_usd_correlated_positions": 3,
    "max_jpy_correlated_positions": 2
